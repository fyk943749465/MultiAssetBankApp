# 生产构建时指向 Go 后端根地址（开发模式用 Vite 代理 /api，一般不用配）
# VITE_API_BASE=http://127.0.0.1:8080

# 可选：Wagmi 读链用 Sepolia RPC（不配则用 viem 默认公共节点，可能被限流）
# VITE_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_KEY

# 可选：借贷模块所在 Base Sepolia RPC（不配则用 viem 默认公共节点）
# VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org

# 可选：WalletConnect v2 Project ID（https://cloud.walletconnect.com ）不配则仅显示 Injected（浏览器钱包）
# VITE_WALLETCONNECT_PROJECT_ID=

# MultiAssetBank 合约地址（默认已写死为 0x668…；覆盖时用）
# VITE_BANK_ADDRESS=0x668A7A8372C41EE0be46a4eA34e6eafeaA4E9748

# NftPlatform 合约地址（Sepolia；不配则与 backend/migrations/005_nft_platform.sql 种子一致）
# VITE_NFT_TEMPLATE_ADDRESS=0xcbbf6cd8d652289a91dc560944108ad962a69599
# VITE_NFT_FACTORY_ADDRESS=0x32ccf2565f382519d6f8ca2fe12ba7a5ac1f8c90
# VITE_NFT_MARKETPLACE_ADDRESS=0x7bf717d5c1262756e80b99f7eb6c8838cea5c9f6

# ── Lending（Base Sepolia；不配则与 subgraph/lending/networks.json 默认一致）──
# 概览页会请求 Go 后端 /api/lending/contracts、supplies、withdrawals 及 007 扩展表对应 GET（reserve-initialized、emode-category-configured 等）；开发时依赖 vite 将 /api 代理到后端（见 vite.config.ts）。
# VITE_LENDING_POOL_ADDRESS=0x3f0248e6ff7e414485a146c18d6b72dc9e317e5f
# VITE_LENDING_HYBRID_ORACLE_ADDRESS=0xe72ac9c1d557d65094ae92739e409ca56ae12b11
# VITE_LENDING_CHAINLINK_ORACLE_ADDRESS=0x3100b1fd5a2180dac11820106579545d0f1c439b
# VITE_LENDING_REPORTS_VERIFIER_ADDRESS=0x960e004f33566d0b56863f54532f1785923d2799
# VITE_LENDING_IR_STRATEGY_FACTORY_ADDRESS=0xb44d1c69eaf762441d6762e094b18d2614cf1617
# VITE_LENDING_IR_STRATEGY_ADDRESS=0x0f4c88d757e370016b5cfc1ac48d013378be4a27
