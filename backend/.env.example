SERVER_ADDR=:8080
DATABASE_URL=postgres://user:password@localhost:5432/gochain?sslmode=disable
# Optional: JSON-RPC endpoint for chain operations
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
# Optional: Sepolia Counter contract (hex address)
COUNTER_CONTRACT_ADDRESS=0xfC64B05482c19E69e1296Acc0C00B954B7528D1a
# Optional: hex key for POST /api/contract/counter/count (testnet only; never commit real keys)
ETH_PRIVATE_KEY=
# Code Pulse：设为 1 才允许 POST /api/code-pulse/tx/submit 用 ETH_PRIVATE_KEY 代签；默认关闭，由前端钱包签名发送
# CODE_PULSE_SERVER_TX=

# MultiAssetBank：链上 Deposited / Withdrawn 事件索引（需 ETH_RPC_URL + 下方地址）
BANK_CONTRACT_ADDRESS=0x668A7A8372C41EE0be46a4eA34e6eafeaA4E9748
# 可选：从该块开始扫（0 表示首次启动时从「当前已确认头 - 2000」起）
BANK_INDEXER_START_BLOCK=
# 历史补数据：若链上早就有充值但库里没有，① 设 BANK_INDEXER_START_BLOCK=合约部署块或第一笔充值所在块之前
# ② 在 PostgreSQL 执行：DELETE FROM chain_indexer_cursors WHERE name LIKE 'multi_asset_bank_%';
# ③ 重启后端，索引器会从起始块重扫，INSERT 遇重复键会跳过（ON CONFLICT DO NOTHING）。

# Bank + Code Pulse RPC 索引器共用（减轻 Infura 429 / -32005）：默认 poll=35s、分块间隔=800ms、每段最多 1000 块
# INDEXER_POLL_SECONDS=45
# INDEXER_FILTER_CHUNK_PAUSE_MS=1200
# INDEXER_MAX_BLOCK_SPAN=1000

# The Graph Studio：后端代理子图查询（不要把 Key 暴露给前端）
# SUBGRAPH_URL=https://api.studio.thegraph.com/query/<STUDIO_QUERY_PATH_ID>/multi-asset-bank-sepolia/version/latest
# SUBGRAPH_API_KEY=


# 开源项目众筹合约的地址（配置且具备 DATABASE_URL + ETH_RPC_URL 后，后端会 RPC 扫块写入 cp_*，与 Bank 索引同模式）
#CODE_PULSE_ADDRESS=0x3100b1FD5A2180dAc11820106579545D0f1C439b
# 可选：RPC 扫块索引起始块（0 表示首次从「当前已确认头 - 约 2000」起，与 BANK_INDEXER_START_BLOCK 行为类似）
# CODE_PULSE_INDEXER_START_BLOCK=

# Code Pulse 子图：供后端代理/前端查询，数据通常比 PG 更早；默认不会写入 PostgreSQL
# SUBGRAPH_CODE_PULSE_URL=https://api.studio.thegraph.com/query/42035/code-pulse-advanced/version/latest
# 仅当需要「子图也往 PG 里同步」时设为 true 或 1（与 RPC 索引双写，一般不必开）
# CODE_PULSE_SUBGRAPH_SYNC=
# 以下为 CODE_PULSE_SUBGRAPH_SYNC 开启时才有意义：
# 子图同步起始块（内部存 块号-1 作为首次 blockNumber_gt；建议设为合约部署块）
# CODE_PULSE_SUBGRAPH_START_BLOCK=
# 子图轮询间隔（秒），默认 25
# CODE_PULSE_SUBGRAPH_POLL_SECONDS=25
